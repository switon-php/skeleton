{
  "name": "switon/skeleton",
  "description": "Official application skeleton and framework distribution for Switon Framework",
  "keywords": [
    "switon",
    "skeleton",
    "starter",
    "distribution",
    "framework"
  ],
  "homepage": "https://github.com/switon-php/skeleton",
  "license": "MIT",
  "authors": [
    {
      "name": "switon",
      "email": "admin@switon.dev"
    }
  ],
  "support": {
    "source": "https://github.com/switon-php/skeleton",
    "issues": "https://github.com/switon-php/skeleton/issues"
  },
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../*",
      "options": {
        "symlink": true,
        "versions": {
          "switon/authz": "1.0.0",
          "switon/beacon": "1.0.0",
          "switon/binding": "1.0.0",
          "switon/cache": "1.0.0",
          "switon/captcha": "1.0.0",
          "switon/cli": "1.0.0",
          "switon/command": "1.0.0",
          "switon/composer-extra": "1.0.0",
          "switon/console": "1.0.0",
          "switon/context": "1.0.0",
          "switon/core": "1.0.0",
          "switon/crypto": "1.0.0",
          "switon/db": "1.0.0",
          "switon/di": "1.0.0",
          "switon/dict": "1.0.0",
          "switon/event": "1.0.0",
          "switon/executor": "1.0.0",
          "switon/http": "1.0.0",
          "switon/http-cache": "1.0.0",
          "switon/http-client": "1.0.0",
          "switon/i18n": "1.0.0",
          "switon/id": "1.0.0",
          "switon/inspector": "1.0.0",
          "switon/invocation": "1.0.0",
          "switon/invoker": "1.0.0",
          "switon/jwt": "1.0.0",
          "switon/kernel": "1.0.0",
          "switon/log": "1.0.0",
          "switon/mail": "1.0.0",
          "switon/openapi": "1.0.0",
          "switon/orm": "1.0.0",
          "switon/orm-codegen": "1.0.0",
          "switon/pool": "1.0.0",
          "switon/principal": "1.0.0",
          "switon/query": "1.0.0",
          "switon/queue": "1.0.0",
          "switon/redis": "1.0.0",
          "switon/renderer": "1.0.0",
          "switon/router": "1.0.0",
          "switon/rpc": "1.0.0",
          "switon/schedule": "1.0.0",
          "switon/session": "1.0.0",
          "switon/sharding": "1.0.0",
          "switon/storage": "1.0.0",
          "switon/sync": "1.0.0",
          "switon/testing": "1.0.0",
          "switon/throttle": "1.0.0",
          "switon/validation": "1.0.0",
          "switon/view": "1.0.0",
          "switon/yaml": "1.0.0"
        }
      }
    }
  ],
  "require": {
    "php": ">=8.3",
    "ext-json": "*",
    "psr/container": "2.0.2",
    "psr/log": "2.0.0",
    "psr/simple-cache": "^3.0",
    "psr/event-dispatcher": "1.0.*",
    "switon/authz": "^1.0",
    "switon/cache": "^1.0",
    "switon/context": "^1.0",
    "switon/cli": "^1.0",
    "switon/core": "^1.0",
    "switon/event": "^1.0",
    "switon/http": "^1.0",
    "switon/id": "^1.0",
    "switon/kernel": "^1.0",
    "switon/composer-extra": "^1.0",
    "switon/log": "^1.0",
    "switon/principal": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "switon/beacon": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Tests\\": "../../tests/"
    },
    "files": [
      "../core/helpers.php",
      "../renderer/helpers.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "switon/composer-extra": true
    }
  },
  "extra": {
    "switon": {
      "version": "0.0.0"
    }
  }
}
