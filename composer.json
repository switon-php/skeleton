{
  "name": "switon/skeleton",
  "description": "Official application skeleton and framework distribution for Switon Framework",
  "keywords": [
    "switon",
    "skeleton",
    "starter",
    "distribution",
    "framework"
  ],
  "homepage": "https://github.com/switon-php/skeleton",
  "license": "MIT",
  "authors": [
    {
      "name": "switon",
      "email": "admin@switon.dev"
    }
  ],
  "support": {
    "source": "https://github.com/switon-php/skeleton",
    "issues": "https://github.com/switon-php/skeleton/issues"
  },
  "prefer-stable": true,
  "require": {
    "php": ">=8.3",
    "ext-json": "*",
    "psr/container": "2.0.2",
    "psr/log": "2.0.0",
    "psr/simple-cache": "^3.0",
    "psr/event-dispatcher": "1.0.*",
    "switon/authz": "^1.0",
    "switon/cache": "^1.0",
    "switon/context": "^1.0",
    "switon/cli": "^1.0",
    "switon/core": "^1.0",
    "switon/event": "^1.0",
    "switon/http": "^1.0",
    "switon/id": "^1.0",
    "switon/kernel": "^1.0",
    "switon/composer-extra": "^1.0",
    "switon/log": "^1.0",
    "switon/principal": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "suggest": {
    "switon/beacon": "Optional Beacon CLI tooling (composer require switon/beacon --dev)"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "allow-plugins": {
      "switon/composer-extra": true
    }
  },
  "extra": {
    "switon": {
      "version": "0.0.0"
    }
  }
}
